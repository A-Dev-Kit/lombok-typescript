{
  "name": "lombok-typescript",
  "version": "0.1.0-pre",
  "description": "Lombok-like decorators and code generation for TypeScript - reduce boilerplate with powerful annotations and Gang-of-Four design patterns",
  "packageManager": "pnpm@10.34.3",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs"
    },
    "./legacy": {
      "types": "./dist/legacy/index.d.ts",
      "import": "./dist/legacy/index.js",
      "require": "./dist/legacy/index.cjs"
    },
    "./stage3": {
      "types": "./dist/stage3/index.d.ts",
      "import": "./dist/stage3/index.js",
      "require": "./dist/stage3/index.cjs"
    },
    "./codegen": {
      "types": "./dist/codegen/index.d.ts",
      "import": "./dist/codegen/index.js",
      "require": "./dist/codegen/index.cjs"
    }
  },
  "bin": {
    "lombok-ts": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .lombok coverage .tsbuildinfo",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "lombok",
    "typescript",
    "decorators",
    "codegen",
    "ts-morph",
    "design-patterns",
    "gof",
    "gang-of-four",
    "builder",
    "data-class",
    "boilerplate",
    "annotations",
    "getter",
    "setter",
    "immutable",
    "singleton",
    "factory",
    "strategy",
    "observer",
    "nestjs"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/A-Dev-Kit/lombok-typescript.git"
  },
  "bugs": {
    "url": "https://github.com/A-Dev-Kit/lombok-typescript/issues"
  },
  "homepage": "https://github.com/A-Dev-Kit/lombok-typescript#readme",
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@vitest/coverage-v8": "^3.2.6",
    "@vitest/ui": "^3.2.6",
    "eslint": "^9.39.4",
    "expect-type": "^1.3.0",
    "globals": "^15.15.0",
    "prettier": "^3.8.4",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^3.2.6"
  },
  "dependencies": {
    "bundle-require": "^5.1.0",
    "cac": "^6.7.14",
    "reflect-metadata": "^0.2.2",
    "ts-morph": "^28.0.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  }
}
