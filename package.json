{
  "name": "@a-dev-kit/lombok-typescript",
  "version": "1.0.0",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "description": "Lombok-like decorators and code generation for TypeScript - reduce boilerplate with powerful annotations and Gang-of-Four design patterns",
  "packageManager": "pnpm@10.34.3",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./core": {
      "import": {
        "types": "./dist/core/index.d.ts",
        "default": "./dist/core/index.js"
      },
      "require": {
        "types": "./dist/core/index.d.cts",
        "default": "./dist/core/index.cjs"
      }
    },
    "./legacy": {
      "import": {
        "types": "./dist/legacy/index.d.ts",
        "default": "./dist/legacy/index.js"
      },
      "require": {
        "types": "./dist/legacy/index.d.cts",
        "default": "./dist/legacy/index.cjs"
      }
    },
    "./stage3": {
      "import": {
        "types": "./dist/stage3/index.d.ts",
        "default": "./dist/stage3/index.js"
      },
      "require": {
        "types": "./dist/stage3/index.d.cts",
        "default": "./dist/stage3/index.cjs"
      }
    },
    "./codegen": {
      "import": {
        "types": "./dist/codegen/index.d.ts",
        "default": "./dist/codegen/index.js"
      },
      "require": {
        "types": "./dist/codegen/index.d.cts",
        "default": "./dist/codegen/index.cjs"
      }
    },
    "./observers/rxjs": {
      "import": {
        "types": "./dist/observers/rxjs.d.ts",
        "default": "./dist/observers/rxjs.js"
      },
      "require": {
        "types": "./dist/observers/rxjs.d.cts",
        "default": "./dist/observers/rxjs.cjs"
      }
    },
    "./observers/mobx": {
      "import": {
        "types": "./dist/observers/mobx.d.ts",
        "default": "./dist/observers/mobx.js"
      },
      "require": {
        "types": "./dist/observers/mobx.d.cts",
        "default": "./dist/observers/mobx.cjs"
      }
    },
    "./validators/zod": {
      "import": {
        "types": "./dist/validators/zod.d.ts",
        "default": "./dist/validators/zod.js"
      },
      "require": {
        "types": "./dist/validators/zod.d.cts",
        "default": "./dist/validators/zod.cjs"
      }
    },
    "./validators/yup": {
      "import": {
        "types": "./dist/validators/yup.d.ts",
        "default": "./dist/validators/yup.js"
      },
      "require": {
        "types": "./dist/validators/yup.d.cts",
        "default": "./dist/validators/yup.cjs"
      }
    },
    "./validators/class-validator": {
      "import": {
        "types": "./dist/validators/class-validator.d.ts",
        "default": "./dist/validators/class-validator.js"
      },
      "require": {
        "types": "./dist/validators/class-validator.d.cts",
        "default": "./dist/validators/class-validator.cjs"
      }
    }
  },
  "bin": {
    "lombok-ts": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "gen-version": "node scripts/gen-version.mjs",
    "build": "node scripts/gen-version.mjs && tsup",
    "build:all": "node scripts/gen-version.mjs && tsup && pnpm --dir packages/nestjs build",
    "build:watch": "tsup --watch",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:all": "vitest run && pnpm build && pnpm --dir packages/nestjs test && pnpm --dir examples/commonjs-serverless typecheck",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "node scripts/gen-version.mjs && tsc --noEmit",
    "clean": "rm -rf dist .lombok coverage .tsbuildinfo",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "lombok",
    "typescript",
    "decorators",
    "codegen",
    "ts-morph",
    "design-patterns",
    "gof",
    "gang-of-four",
    "builder",
    "data-class",
    "boilerplate",
    "annotations",
    "getter",
    "setter",
    "immutable",
    "singleton",
    "factory",
    "strategy",
    "observer",
    "nestjs"
  ],
  "author": "A-Dev-Kit",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/A-Dev-Kit/lombok-typescript.git"
  },
  "bugs": {
    "url": "https://github.com/A-Dev-Kit/lombok-typescript/issues"
  },
  "homepage": "https://github.com/A-Dev-Kit/lombok-typescript#readme",
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "eslint": "^10.6.0",
    "expect-type": "^1.4.0",
    "globals": "^17.7.0",
    "mobx": "^6.15.0",
    "prettier": "^3.9.1",
    "rxjs": "^7.8.2",
    "yup": "^1.6.0",
    "zod": "^3.24.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "bundle-require": "^5.1.0",
    "cac": "^7.0.0",
    "reflect-metadata": "^0.2.2",
    "ts-morph": "^28.0.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0",
    "rxjs": ">=7.0.0",
    "mobx": ">=6.0.0",
    "zod": ">=3.0.0",
    "yup": ">=1.0.0",
    "class-validator": ">=0.14.0"
  },
  "peerDependenciesMeta": {
    "rxjs": {
      "optional": true
    },
    "mobx": {
      "optional": true
    },
    "zod": {
      "optional": true
    },
    "yup": {
      "optional": true
    },
    "class-validator": {
      "optional": true
    }
  }
}
