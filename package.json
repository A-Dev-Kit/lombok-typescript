{
  "name": "@a-dev-kit/lombok-typescript",
  "version": "0.10.0",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "description": "Lombok-like decorators and code generation for TypeScript - reduce boilerplate with powerful annotations and Gang-of-Four design patterns",
  "packageManager": "pnpm@10.34.3",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs"
    },
    "./legacy": {
      "types": "./dist/legacy/index.d.ts",
      "import": "./dist/legacy/index.js",
      "require": "./dist/legacy/index.cjs"
    },
    "./stage3": {
      "types": "./dist/stage3/index.d.ts",
      "import": "./dist/stage3/index.js",
      "require": "./dist/stage3/index.cjs"
    },
    "./codegen": {
      "types": "./dist/codegen/index.d.ts",
      "import": "./dist/codegen/index.js",
      "require": "./dist/codegen/index.cjs"
    },
    "./observers/rxjs": {
      "types": "./dist/observers/rxjs.d.ts",
      "import": "./dist/observers/rxjs.js",
      "require": "./dist/observers/rxjs.cjs"
    },
    "./observers/mobx": {
      "types": "./dist/observers/mobx.d.ts",
      "import": "./dist/observers/mobx.js",
      "require": "./dist/observers/mobx.cjs"
    },
    "./validators/zod": {
      "types": "./dist/validators/zod.d.ts",
      "import": "./dist/validators/zod.js",
      "require": "./dist/validators/zod.cjs"
    },
    "./validators/yup": {
      "types": "./dist/validators/yup.d.ts",
      "import": "./dist/validators/yup.js",
      "require": "./dist/validators/yup.cjs"
    },
    "./validators/class-validator": {
      "types": "./dist/validators/class-validator.d.ts",
      "import": "./dist/validators/class-validator.js",
      "require": "./dist/validators/class-validator.cjs"
    }
  },
  "bin": {
    "lombok-ts": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .lombok coverage .tsbuildinfo",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "lombok",
    "typescript",
    "decorators",
    "codegen",
    "ts-morph",
    "design-patterns",
    "gof",
    "gang-of-four",
    "builder",
    "data-class",
    "boilerplate",
    "annotations",
    "getter",
    "setter",
    "immutable",
    "singleton",
    "factory",
    "strategy",
    "observer",
    "nestjs"
  ],
  "author": "A-Dev-Kit",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/A-Dev-Kit/lombok-typescript.git"
  },
  "bugs": {
    "url": "https://github.com/A-Dev-Kit/lombok-typescript/issues"
  },
  "homepage": "https://github.com/A-Dev-Kit/lombok-typescript#readme",
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "eslint": "^10.5.0",
    "expect-type": "^1.3.0",
    "globals": "^17.6.0",
    "mobx": "^6.15.0",
    "prettier": "^3.8.4",
    "rxjs": "^7.8.2",
    "yup": "^1.6.0",
    "zod": "^4.4.3",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "bundle-require": "^5.1.0",
    "cac": "^7.0.0",
    "reflect-metadata": "^0.2.2",
    "ts-morph": "^28.0.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0",
    "rxjs": ">=7.0.0",
    "mobx": ">=6.0.0",
    "zod": ">=3.0.0",
    "yup": ">=1.0.0",
    "class-validator": ">=0.14.0"
  },
  "peerDependenciesMeta": {
    "rxjs": {
      "optional": true
    },
    "mobx": {
      "optional": true
    },
    "zod": {
      "optional": true
    },
    "yup": {
      "optional": true
    },
    "class-validator": {
      "optional": true
    }
  }
}
